# Enable mod_rewrite
RewriteEngine On

# Pass Authorization header through to PHP (Apache/XAMPP strips it by default)
RewriteRule ^ - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# Set MIME types for media files
<FilesMatch "\.(mp4|webm|ogg|mp3|wav)$">
    Header set Content-Type "video/mp4"
</FilesMatch>

# Handle client-side routing
RewriteBase /
RewriteRule ^index\.html$ - [L]

# Don't rewrite real files or directories
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Don't rewrite api requests
RewriteCond %{REQUEST_URI} !^/api/

# Don't rewrite static assets (videos, images, etc.)
RewriteCond %{REQUEST_URI} !^/videos/
RewriteCond %{REQUEST_URI} !^/images/

# Rewrite everything else to index.html for SPA routing
RewriteRule . /index.html [L]