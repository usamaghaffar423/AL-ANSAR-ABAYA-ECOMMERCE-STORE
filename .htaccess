# Enable mod_rewrite
RewriteEngine On

# Pass Authorization header through to PHP
RewriteRule ^ - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# Set MIME types for media files
<FilesMatch "\.(mp4|webm|ogg|mp3|wav)$">
    Header set Content-Type "video/mp4"
</FilesMatch>

RewriteBase /

# Don't rewrite index.html itself
RewriteRule ^index\.html$ - [L]

# Don't rewrite real files (has extension like .php, .js, .css, .txt, etc)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Don't rewrite real directories
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Rewrite SPA routes to index.html (only paths without dots)
RewriteRule ^[^.]*$ /index.html [L]