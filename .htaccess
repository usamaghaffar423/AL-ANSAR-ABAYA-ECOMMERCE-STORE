# Enable mod_rewrite
RewriteEngine On

# Pass Authorization header through to PHP
RewriteRule ^ - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# Set MIME types for media files
<FilesMatch "\.(mp4|webm|ogg|mp3|wav)$">
    Header set Content-Type "video/mp4"
</FilesMatch>

RewriteBase /

# Explicitly don't rewrite these extensions
RewriteRule \.(php|js|css|jpg|jpeg|png|gif|txt|svg|woff|woff2|ttf|eot)$ - [L]

# Don't rewrite api folder
RewriteRule ^api/ - [L]

# Don't rewrite index.html
RewriteRule ^index\.html$ - [L]

# Don't rewrite real files or directories
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Rewrite everything else to index.html
RewriteRule ^ /index.html [L]